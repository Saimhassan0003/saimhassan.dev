# ============================================
# PORTFOLIO BACKEND CONFIGURATION
# ============================================

# Server Port
PORT=5000

# Node Environment (development, production, test)
NODE_ENV=development

# ============================================
# MONGODB CONFIGURATION
# ============================================

# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# Get this from: https://cloud.mongodb.com/ -> Connect -> Copy connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# ============================================
# EMAIL CONFIGURATION (Gmail)
# ============================================

# Gmail Address (the email that will send notifications)
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your password, create an app password)
# Steps to create app password:
# 1. Go to https://myaccount.google.com/
# 2. Security -> App passwords (requires 2FA to be enabled)
# 3. Select Mail and Windows Computer
# 4. Copy the 16-character password and paste here
EMAIL_PASS=your-app-password

# Admin Email (where to send contact notifications)
# Can be the same as EMAIL_USER or different
ADMIN_EMAIL=your-gmail@gmail.com

# ============================================
# SETUP INSTRUCTIONS
# ============================================

# 1. MONGODB SETUP:
#    - Create account: https://cloud.mongodb.com/
#    - Create a free cluster (M0 tier)
#    - Click "Connect" -> "Drivers" -> Node.js
#    - Copy connection string and replace username:password
#    - Keep database name as "portfolio"

# 2. GMAIL SETUP:
#    - Enable 2-Factor Authentication on your Google Account
#    - Visit: https://myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer"
#    - Copy the 16-character password
#    - Paste as EMAIL_PASS value

# 3. ENV SETUP:
#    - Copy this file to .env
#    - Replace all placeholder values with your actual credentials
#    - NEVER commit .env file to git
